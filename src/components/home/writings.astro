---
import { getCollection } from "astro:content";
import { wordCount } from "../../helpers";
import Button from "../button.astro";
import PostsSkeleton from "../posts-skeleton.astro";

const localPosts = await getCollection("post", ({ data }) => data.status === "published");
const localPostsData = localPosts
  .sort((a, b) => new Date(b.data.dateFormatted).getTime() - new Date(a.data.dateFormatted).getTime())
  .map((p) => ({
    title: p.data.title,
    link: `/post/${p.slug}/`,
    pubDate: p.data.dateFormatted,
    description: p.data.description,
    thumbnail: p.data.coverImage,
    readTime: Number(wordCount(p.data.wordCount)),
    source: "local",
  }));
---

<section class="max-w-4xl mx-auto px-7 lg:px-0">
  <h2
    class="text-2xl font-bold leading-10 tracking-tight text-neutral-900 dark:text-neutral-100"
  >
    Stuff I Think About
  </h2>
  <p class="mb-6 text-base text-neutral-600 dark:text-neutral-400">
    Mostly tech, sometimes life. I write when something's worth sharing.
  </p>

  <div class="w-full max-w-4xl mx-auto my-7 xl:px-0">
    <div class="flex flex-col items-start justify-start md:flex-row md:space-x-7 md:items-start">
      <div class="w-full md:w-2/3 space-y-7">
        <PostsSkeleton count={3} localPosts={localPostsData} />

        <div class="flex items-center justify-center w-full py-5">
          <Button text="See Everything I've Written" link="/posts" />
        </div>
      </div>

      <div class="w-full mt-10 md:w-1/3 md:mt-0">
        <div class="p-6 border border-dashed rounded-2xl border-neutral-300 dark:border-neutral-600">
          <div class="flex items-center space-x-2 mb-3">
            <svg
              class="flex-none w-5 h-5 text-neutral-700 dark:text-neutral-200"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z"
              />
            </svg>
            <h2 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100">
              Subscribe to my blog
            </h2>
          </div>
          <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-5 leading-relaxed">
            Get notified whenever I publish a new article on Medium. No spam, just writing.
          </p>
          <a
            href="https://afifalfiano.medium.com/subscribe"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center w-full gap-2 px-4 py-2.5 text-sm font-medium text-white bg-neutral-900 hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-300 rounded-xl transition-colors duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 1043.63 592.71" fill="currentColor">
              <path d="M588.67 296.36c0 163.67-131.78 296.35-294.33 296.35S0 460 0 296.36 131.78 0 294.34 0s294.33 132.69 294.33 296.36M911.56 296.36c0 154.06-65.89 279-147.17 279s-147.17-124.94-147.17-279 65.88-279 147.17-279 147.17 124.9 147.17 279M1043.63 296.36c0 138-23.17 249.94-51.76 249.94s-51.75-111.91-51.75-249.94 23.17-249.94 51.75-249.94 51.76 111.9 51.76 249.94"/>
            </svg>
            Follow on Medium
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
