---
const OPTIONS: Intl.DateTimeFormatOptions = { year: "numeric", month: "long", day: "numeric" };

const { count } = Astro.props;

type Post = { title: string; link: string; pubDate: string; description: string; thumbnail: string };

let postsLoop: Post[] = [];
try {
  const apiKey = import.meta.env.RSS2JSON_API_KEY;
  const res = await fetch(
    `https://api.rss2json.com/v1/api.json?rss_url=https://medium.com/feed/@afifalfiano&api_key=${apiKey}&count=100`
  );
  const data = await res.json();
  if (data.status === "ok") {
    postsLoop = data.items.map((item: Record<string, string>) => {
      const imgMatch = item.content?.match(/<img[^>]+src="([^"]+)"/);
      const thumbnail = item.thumbnail || (imgMatch ? imgMatch[1] : "");
      return {
        title: item.title,
        link: item.link,
        pubDate: item.pubDate,
        thumbnail,
        description: item.description.replace(/<[^>]+>/g, " ").replace(/\s+/g, " ").trim(),
      };
    }).slice(0, count);
  }
} catch (e) {
  console.error("Failed to fetch Medium posts", e);
}
---

{
  postsLoop.map((post) => {
    return (
      <div
        class="relative border border-transparent border-dashed cursor-pointer p-7 group rounded-2xl"
        onclick={`window.open('${post.link}', '_blank')`}
      >
        <div class="absolute inset-0 z-20 w-full h-full duration-300 ease-out bg-white border border-dashed dark:bg-neutral-950 rounded-2xl border-neutral-300 dark:border-neutral-600 group-hover:-translate-x-1 group-hover:-translate-y-1" />
        <div class="absolute inset-0 z-10 w-full h-full duration-300 ease-out border border-dashed rounded-2xl border-neutral-300 dark:border-neutral-600 group-hover:translate-x-1 group-hover:translate-y-1" />
        <div class="relative z-30 duration-300 ease-out group-hover:-translate-x-1 group-hover:-translate-y-1">
          <div class="flex gap-5 items-center">
          {post.thumbnail && (
            <div class="flex-shrink-0 w-24 h-24 sm:w-32 sm:h-32 overflow-hidden rounded-xl">
              <img
                src={post.thumbnail}
                alt={post.title}
                class="w-full h-full object-cover object-center"
              />
            </div>
          )}
          <div class="flex-1 min-w-0">
          <h2 class="flex items-center mb-2">
            <a
              href={post.link}
              target="_blank"
              rel="noopener noreferrer"
              class="text-base font-bold leading-snug tracking-tight sm:text-lg dark:text-neutral-100"
            >
              {post.title}
            </a>
            <svg
              class="group-hover:translate-x-0 flex-shrink-0 translate-y-0.5 -translate-x-1 w-2.5 h-2.5 stroke-current ml-1 transition-all ease-in-out duration-200  transform"
              viewBox="0 0 13 15"
              version="1.1"
              xmlns="http://www.w3.org/2000/svg"
              xmlns:xlink="http://www.w3.org/1999/xlink"
            >
              <g
                stroke="none"
                stroke-width="1"
                fill="none"
                fill-rule="evenodd"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <g
                  id="svg"
                  transform="translate(0.666667, 2.333333)"
                  stroke="currentColor"
                  stroke-width="2.4"
                >
                  <g>
                    <>
                      <polyline
                        class="transition-all duration-200 ease-out opacity-0 delay-0 group-hover:opacity-100"
                        points="5.33333333 0 10.8333333 5.5 5.33333333 11"
                      />
                      <line
                        class="transition-all duration-200 ease-out transform -translate-x-1 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 group-hover:ml-0"
                        x1="10.8333333"
                        y1="5.5"
                        x2="0.833333333"
                        y2="5.16666667"
                      />
                    </>
                  </g>
                </g>
              </g>
            </svg>
          </h2>
          <p class="text-sm text-neutral-600 dark:text-neutral-400">
            <span>{post.description.length > 150 ? post.description.slice(0, 150) + '...' : post.description}</span>
          </p>
          <div class="mt-2.5 text-xs font-medium text-neutral-800 dark:text-neutral-300">
            Posted on {new Date(post.pubDate).toLocaleDateString('en-US', OPTIONS)}
          </div>
          </div>
          </div>
        </div>
      </div>
    )
  })
}
