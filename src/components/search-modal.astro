---
const rssKey = import.meta.env.RSS2JSON_API_KEY ?? "";
---

<!-- Backdrop -->
<div
  id="search-backdrop"
  class="hidden fixed inset-0 z-[100] bg-black/40 dark:bg-black/60 backdrop-blur-sm"
></div>

<!-- Modal -->
<div
  id="search-modal"
  data-rss-key={rssKey}
  class="hidden fixed z-[101] top-[10%] sm:top-[15%] left-1/2 -translate-x-1/2 w-[calc(100%-2rem)] max-w-xl bg-white dark:bg-neutral-900 border border-dashed border-neutral-300 dark:border-neutral-700 rounded-2xl shadow-2xl overflow-hidden"
>
  <!-- Input row -->
  <div
    class="flex items-center gap-3 px-4 py-3 border-b border-dashed border-neutral-200 dark:border-neutral-800"
  >
    <svg
      class="flex-shrink-0 w-4 h-4 text-neutral-400 dark:text-neutral-500"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      viewBox="0 0 24 24"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.35-4.35"></path>
    </svg>
    <input
      id="search-input"
      type="text"
      placeholder="Search posts, projects, talks…"
      autocomplete="off"
      class="flex-1 bg-transparent text-sm text-neutral-900 dark:text-neutral-100 placeholder:text-neutral-400 dark:placeholder:text-neutral-500 outline-none"
    />
    <kbd
      class="hidden sm:inline-flex text-[10px] px-1.5 py-0.5 rounded bg-neutral-100 dark:bg-neutral-800 text-neutral-500 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-700"
      >ESC</kbd
    >
  </div>

  <!-- Results -->
  <ul id="search-results" class="max-h-[60vh] overflow-y-auto"></ul>

  <!-- Footer hints -->
  <div
    id="search-footer"
    class="hidden px-4 py-2 text-xs text-neutral-400 dark:text-neutral-500 border-t border-dashed border-neutral-200 dark:border-neutral-800 flex items-center gap-4"
  >
    <span>↑↓ navigate</span>
    <span>↵ open</span>
    <span>ESC close</span>
  </div>
</div>

<script>
  import { pushEvent } from "../assets/js/gtm-events";

  type SearchItem = {
    id: string;
    type: "post" | "project" | "talk" | "experience" | "medium";
    title: string;
    description: string;
    url: string;
    tags: string[];
    meta: string;
  };

  let staticIndex: SearchItem[] = [];
  let mediumPosts: SearchItem[] = [];
  let indexLoaded = false;
  let mediumLoaded = false;
  let selectedIndex = -1;
  let currentResults: SearchItem[] = [];

  const backdrop = document.getElementById("search-backdrop") as HTMLElement;
  const modal = document.getElementById("search-modal") as HTMLElement;
  const input = document.getElementById("search-input") as HTMLInputElement;
  const resultsList = document.getElementById(
    "search-results",
  ) as HTMLUListElement;
  const footer = document.getElementById("search-footer") as HTMLElement;

  const TYPE_COLORS: Record<string, string> = {
    page: "text-cyan-600 dark:text-cyan-400",
    post: "text-blue-600 dark:text-blue-400",
    project: "text-violet-600 dark:text-violet-400",
    talk: "text-green-600 dark:text-green-400",
    experience: "text-orange-600 dark:text-orange-400",
    medium: "text-neutral-500 dark:text-neutral-400",
  };

  function buildHaystack(item: SearchItem): string {
    return [item.title, item.description, item.tags.join(" "), item.meta]
      .join(" ")
      .toLowerCase();
  }

  function matchesQuery(item: SearchItem, query: string): boolean {
    const q = query.toLowerCase().trim();
    if (!q) return false;
    const haystack = buildHaystack(item);
    return q.split(/\s+/).every((token) => haystack.includes(token));
  }

  function renderResults(query: string) {
    const all = [...staticIndex, ...mediumPosts];
    currentResults = query.trim()
      ? all.filter((item) => matchesQuery(item, query))
      : [];

    selectedIndex = -1;
    resultsList.innerHTML = "";

    if (!query.trim()) {
      footer.classList.add("hidden");
      return;
    }

    if (currentResults.length === 0) {
      const empty = document.createElement("li");
      empty.className =
        "px-4 py-6 text-sm text-center text-neutral-400 dark:text-neutral-500";
      empty.textContent = "No results found.";
      resultsList.appendChild(empty);
      footer.classList.add("hidden");
      return;
    }

    for (let i = 0; i < currentResults.length; i++) {
      const item = currentResults[i];
      const isExternal = item.url.startsWith("http");
      const colorClass = TYPE_COLORS[item.type] ?? TYPE_COLORS.medium;

      const li = document.createElement("li");
      li.dataset.index = String(i);
      li.className =
        "flex items-start gap-3 px-4 py-3 cursor-pointer hover:bg-neutral-50 dark:hover:bg-neutral-800/60 transition-colors duration-150";

      const badge = document.createElement("span");
      badge.className = `mt-0.5 flex-shrink-0 text-xs px-2 py-0.5 rounded-full bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 capitalize ${colorClass}`;
      badge.textContent = item.type;

      const content = document.createElement("div");
      content.className = "flex-1 min-w-0";

      const titleRow = document.createElement("div");
      titleRow.className = "flex items-center gap-1";

      const title = document.createElement("p");
      title.className =
        "text-sm font-medium text-neutral-900 dark:text-neutral-100 truncate";
      title.textContent = item.title;
      titleRow.appendChild(title);

      if (isExternal) {
        const ext = document.createElement("svg");
        ext.setAttribute("class", "flex-shrink-0 w-3 h-3 text-neutral-400");
        ext.setAttribute("fill", "none");
        ext.setAttribute("stroke", "currentColor");
        ext.setAttribute("stroke-width", "2");
        ext.setAttribute("stroke-linecap", "round");
        ext.setAttribute("stroke-linejoin", "round");
        ext.setAttribute("viewBox", "0 0 24 24");
        ext.innerHTML =
          '<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>';
        titleRow.appendChild(ext);
      }

      const desc = document.createElement("p");
      desc.className =
        "text-xs text-neutral-500 dark:text-neutral-400 mt-0.5 line-clamp-2";
      desc.textContent =
        item.description.length > 120
          ? `${item.description.slice(0, 120)}…`
          : item.description;

      content.appendChild(titleRow);
      content.appendChild(desc);
      li.appendChild(badge);
      li.appendChild(content);

      li.addEventListener("click", () => navigateTo(item.url, item, i));
      resultsList.appendChild(li);
    }

    footer.classList.remove("hidden");
  }

  function setSelectedIndex(idx: number) {
    const items = resultsList.querySelectorAll("li[data-index]");
    for (const el of items) el.classList.remove("bg-neutral-50", "dark:bg-neutral-800/60");

    selectedIndex = Math.max(-1, Math.min(idx, currentResults.length - 1));

    if (selectedIndex >= 0) {
      const target = resultsList.querySelector(
        `li[data-index="${selectedIndex}"]`,
      );
      if (target) {
        target.classList.add("bg-neutral-50", "dark:bg-neutral-800/60");
        target.scrollIntoView({ block: "nearest" });
      }
    }
  }

  function navigateTo(url: string, item?: SearchItem, position?: number) {
    if (item) {
      pushEvent("search_result_click", {
        search_term: input.value.trim(),
        result_title: item.title,
        result_type: item.type,
        result_position: (position ?? 0) + 1,
      });
    }
    if (url.startsWith("http")) {
      window.open(url, "_blank", "noopener,noreferrer");
    } else {
      window.location.href = url;
    }
    closeModal();
  }

  async function fetchStatic() {
    if (indexLoaded) return;
    try {
      const res = await fetch("/search-index.json");
      if (res.ok) {
        staticIndex = await res.json();
      }
    } catch {
      // silently fail — search still works with empty array
    }
    indexLoaded = true;
  }

  async function fetchMedium() {
    if (mediumLoaded) return;
    try {
      const rssKey = modal.dataset.rssKey;
      const url = `https://api.rss2json.com/v1/api.json?rss_url=https://medium.com/feed/@afifalfiano&api_key=${rssKey}&count=100`;
      const res = await fetch(url);
      const data = await res.json();
      if (data.status === "ok") {
        mediumPosts = (data.items as Record<string, string>[]).map((item) => ({
          id: `medium-${item.guid ?? item.link}`,
          type: "medium" as const,
          title: item.title,
          description: item.description
            ? item.description.replace(/<[^>]+>/g, " ").replace(/\s+/g, " ").trim().slice(0, 200)
            : "",
          url: item.link,
          tags: [],
          meta: "",
        }));
      }
    } catch {
      // silently fail
    }
    mediumLoaded = true;
  }

  async function loadData() {
    await Promise.all([fetchStatic(), fetchMedium()]);
    // Re-render with current query after data loads
    renderResults(input.value);
  }

  function openModal() {
    backdrop.classList.remove("hidden");
    modal.classList.remove("hidden");
    input.value = "";
    resultsList.innerHTML = "";
    footer.classList.add("hidden");
    selectedIndex = -1;
    currentResults = [];
    requestAnimationFrame(() => input.focus());
    if (!indexLoaded || !mediumLoaded) {
      loadData();
    }
    pushEvent("search_open");
  }

  function closeModal() {
    backdrop.classList.add("hidden");
    modal.classList.add("hidden");
    input.value = "";
    resultsList.innerHTML = "";
    footer.classList.add("hidden");
    selectedIndex = -1;
    currentResults = [];
  }

  // Input handler with debounce
  let debounceTimer: ReturnType<typeof setTimeout>;
  let searchEventTimer: ReturnType<typeof setTimeout>;
  input.addEventListener("input", () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => renderResults(input.value), 150);

    // Separate 500ms debounce for search_query event (≥3 chars threshold)
    clearTimeout(searchEventTimer);
    searchEventTimer = setTimeout(() => {
      const query = input.value.trim();
      if (query.length >= 3) {
        pushEvent("search_query", {
          search_term: query,
          result_count: currentResults.length,
        });
      }
    }, 500);
  });

  // Keyboard navigation inside modal
  input.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "ArrowDown") {
      e.preventDefault();
      setSelectedIndex(selectedIndex + 1);
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      setSelectedIndex(selectedIndex - 1);
    } else if (e.key === "Enter") {
      e.preventDefault();
      if (selectedIndex >= 0 && currentResults[selectedIndex]) {
        navigateTo(currentResults[selectedIndex].url, currentResults[selectedIndex], selectedIndex);
      }
    } else if (e.key === "Escape") {
      closeModal();
    }
  });

  // Close on backdrop click
  backdrop.addEventListener("click", closeModal);

  // Search toggle button in header
  document.getElementById("searchToggle")?.addEventListener("click", openModal);

  // Global Cmd+K / Ctrl+K shortcut
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      if (modal.classList.contains("hidden")) {
        openModal();
      } else {
        closeModal();
      }
    }
  });
</script>
