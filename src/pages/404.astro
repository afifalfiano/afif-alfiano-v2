---
import Layout from "../layouts/main.astro";
---

<Layout title="404 — Page Not Found | AA" description="This page doesn't exist.">
  <section class="relative z-20 flex flex-col items-center justify-center min-h-[60vh] max-w-2xl mx-auto px-7 lg:px-0 text-center">
    <p class="text-8xl font-bold text-neutral-200 dark:text-neutral-800 select-none">404</p>
    <h1 class="mt-2 text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100">
      Page not found
    </h1>
    <p class="mt-3 text-sm text-neutral-500 dark:text-neutral-400 max-w-sm">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="flex gap-3 mt-8">
      <a
        href="/"
        class="px-5 py-2.5 text-sm font-semibold rounded-full bg-neutral-900 dark:bg-neutral-100 text-white dark:text-neutral-900 hover:opacity-80 transition-opacity duration-200"
      >
        Go home
      </a>
      <a
        href="/posts"
        class="px-5 py-2.5 text-sm font-semibold rounded-full border border-dashed border-neutral-300 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors duration-200"
      >
        Read posts
      </a>
    </div>
  </section>
</Layout>
